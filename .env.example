# BotForge — Secrets / Environment Variables
# Diese Datei NIEMALS ins Repo committen!
# Kopiere als .env und trage deine echten Werte ein.

# ============================================
# Discord Bot (Developer Portal: discord.com/developers)
# ============================================
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_CLIENT_SECRET=your-oauth2-client-secret
DISCORD_PUBLIC_KEY=your-interactions-public-key
PREFIX=!

# ============================================
# Dashboard OAuth2
# ============================================
# Für lokale Entwicklung:
REDIRECT_URI=http://localhost:5000/callback
# Für Production (Railway):
# REDIRECT_URI=https://deine-app.up.railway.app/callback

SESSION_SECRET=change-me-to-a-long-random-string

# ============================================
# Database (MongoDB Atlas: mongodb.com)
# ============================================
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/botforge?retryWrites=true&w=majority

# ============================================
# Music — Lavalink
# ============================================
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# ============================================
# Railway / Hosting
# ============================================
PORT=5000
DASHBOARD_HOST=0.0.0.0

# ============================================
# Optional: Sentry für Error-Tracking
# ============================================
# SENTRY_DSN=https://...

# ============================================
# Optional: OpenAI für KI-AutoMod
# ============================================
# OPENAI_API_KEY=sk-...
